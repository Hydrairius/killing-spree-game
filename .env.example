# Cloudflare API token for Wrangler deploy
# Copy this file to .env and add your token (do not commit .env)
# Get a token: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_token_here

# Bug Report: API for D1 storage. Defaults to /api/bugreports (same-origin) when unset.
# Override for custom domain: VITE_BUGREPORT_WEBHOOK_URL=https://your-domain.com/api/bugreports
# Disable remote: VITE_BUGREPORT_WEBHOOK_URL=off
# VITE_BUGREPORT_WEBHOOK_URL=
